function function_multilevel_baz_1 (a: t) {
    return 9 * a
}

function function_multilevel_baz_2 (b: t) {
    return b + 3
}

function function_multilevel_baz (a: t, b: t) {
    return function_multilevel_baz_1(a) + function_multilevel_baz_2(b)
}

function function_multilevel_bar_1 (c: t) {
    return c + c + c
}

function function_multilevel_bar_2 (d: t) {
    return d + d - d
}

function function_multilevel_bar (c: t, d: t) {
    return function_multilevel_bar_1(c) + function_multilevel_bar_2(d)
}

function function_multilevel_foo (a: t, b: t, c: t, d: t) {
    return function_multilevel_baz(a, b) + function_multilevel_bar(c, d)
}

function function_multilevel_main ( ) {
    return function_multilevel_foo(1, 3, 4, 5)
}
