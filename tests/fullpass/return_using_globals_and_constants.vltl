constant return_using_globals_and_constants_zero = 0
constant return_using_globals_and_constants_one = 1
constant return_using_globals_and_constants_the_number_two = 2
constant return_using_globals_and_constants_the_number_three = 3
global return_using_globals_and_constants_myglobal_a = return_using_globals_and_constants_one + return_using_globals_and_constants_the_number_two
global return_using_globals_and_constants_myglobal_b = return_using_globals_and_constants_one - return_using_globals_and_constants_zero + return_using_globals_and_constants_the_number_three

function return_using_globals_and_constants_main ( ) {
    return return_using_globals_and_constants_the_number_two + return_using_globals_and_constants_the_number_three + return_using_globals_and_constants_myglobal_a + return_using_globals_and_constants_myglobal_b
}
