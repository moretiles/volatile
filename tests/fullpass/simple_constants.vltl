constant simple_constants_zero = 0
constant simple_constants_one = 3 / 3 + 2 / 3

function simple_constants_main ( ) {
    3 - 1 + simple_constants_zero
    simple_constants_zero + simple_constants_zero + simple_constants_zero + simple_constants_one
    return simple_constants_one + simple_constants_zero - 0
}
